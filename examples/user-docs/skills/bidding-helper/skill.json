{
  "schema_version": "ah32.skill.v1",
  "meta": {
    "id": "bidding-helper",
    "name": "招投标助手",
    "version": "0.2.2",
    "enabled": true,
    "priority": 40,
    "description": "面向招投标/标书场景：符合性偏离矩阵、问题清单、证据定位、风险与整改建议。",
    "group": "bidding"
  },
  "routing": {
    "hosts": [
      "writer"
    ],
    "tags": [
      "招投标",
      "投标",
      "标书",
      "招标文件",
      "响应",
      "符合性",
      "偏离",
      "澄清",
      "评分"
    ],
    "intents": [
      "bidding",
      "compliance_matrix",
      "risk"
    ],
    "triggers": [
      "招标",
      "投标",
      "标书",
      "招标文件",
      "投标文件",
      "响应文件",
      "资格审查",
      "门槛",
      "符合性",
      "偏离",
      "偏离表",
      "响应表",
      "技术条款",
      "商务条款",
      "评分",
      "技术响应",
      "商务响应",
      "澄清",
      "答疑",
      "应答"
    ],
    "examples": [
      "根据招标文件输出符合性偏离表，并列出需要澄清的问题",
      "把技术条款逐条应答，给出证据定位与风险提示"
    ]
  },
  "output": {
    "markers": [
      "符合性偏离矩阵",
      "投标响应自查矩阵",
      "招标文件检测报告",
      "问题清单表",
      "修改建议",
      "低价风险提示",
      "投诉处理初审意见",
      "证据定位",
      "风险与建议",
      "自检清单"
    ],
    "output_schema": "输出必须优先采用块级写回，并显式保留用户要求的标题与表头。若用户要求“问题清单表/对照表/矩阵”，必须至少生成 1 张非空表格，表头要写入文档中可见。常用交付结构：1) 执行摘要；2) 表格主体（例如：问题类别/条款定位/判断依据/修改建议，或 招标要求/当前响应/证据定位/风险提示/修改动作）；3) 风险分级或低价风险提示；4) 自检/整改建议。遇到投标响应自查/合规自查类需求时，标题优先使用《投标响应自查矩阵》，表格表头保留“修改动作”，并单独保留“低价风险提示”小节。不要把关键信息只藏在不可见元数据里。若用户明确要求“写回文末 / 块级交付 / 只输出 Plan JSON”，最终回复只能是 ah32.plan.v1 的 Plan JSON，不能输出解释文字、Markdown 包装或纯文本草稿。",
    "max_chars": 3600,
    "styleSpecHints": {
      "writer": {
        "font": {
          "body": {
            "name": "宋体",
            "size": 12
          }
        },
        "table": {
          "header": {
            "bold": true,
            "fill": "#f1f5f9"
          }
        }
      },
      "group": "bidding",
      "schema": "ah32.styleSpecHints.v1"
    }
  },
  "entry": {
    "system_prompt": "SYSTEM.md"
  },
  "delivery": {
    "default_writeback": "direct"
  },
  "capabilities": {
    "rag_missing_hint": true,
    "active_doc_text": true,
    "active_doc_max_chars": 80000
  }
}
